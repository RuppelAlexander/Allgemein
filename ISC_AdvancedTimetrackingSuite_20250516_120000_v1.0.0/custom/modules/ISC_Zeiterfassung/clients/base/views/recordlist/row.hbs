{{#if rowModel}}
    {{#with rowModel}}
        <!--ISC GmbH 07.06.2019 RK: Added double click to edit-->
        <tr name="{{module}}_{{attributes.id}}" class="single" ondblclick="App.controller.context.trigger('isc:editClicked', this.attributes[0].value)">
            {{#each ../leftColumns}}
                <td>
                    {{field ../../this model=../this template=../../viewName}}
                </td>
            {{/each}}
            {{#each ../_fields.visible}}
                <td{{#if align}} class="{{align}}"{{/if}} data-type="{{type}}">
                    {{field ../../this model=../this template=../../viewName}}
                </td>
            {{/each}}
            {{#each ../rightColumns}}
                <td>
                    {{field ../../this model=../this template=../../viewName}}
                </td>
            {{/each}}
        </tr>
    {{/with}}
{{else}}<!--ISC GmbH 11.01.2019 RK: Added double click to edit-->
    <tr name="{{module}}_{{model.id}}" class="single" ondblclick="App.controller.context.trigger('isc:editClicked', this.attributes[0].value)">
        {{#each view.leftColumns}}
            <td>
                {{field ../view model=../model template=../view.viewName}}
            </td>
        {{/each}}
        {{#each view._fields.visible}}
            <td{{#if align}} class="{{align}}"{{/if}} data-type="{{type}}">
                {{field ../view model=../model template=../view.viewName}}
            </td>
        {{/each}}
        {{#each view.rightColumns}}
            <td>
                {{field ../view model=../model template=../view.viewName}}
            </td>
        {{/each}}
    </tr>
{{/if}}
