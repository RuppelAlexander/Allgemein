services:
    suiteweb:
        container_name: ${BASE_NAME}-web1
        image: sugarcrmdevelopers/sugardockerized:php8.2-apache-latest
        ports:
            - ${SUGAR_PORT}:80
        environment:
            - "APACHE_RUN_USER=sugar"
            - "APACHE_RUN_GROUP=sugar"
        volumes:
            - type: bind
              source: ../../data/app
              target: /var/www/html
            - ../../images/suitecrm/config/apache/sites_714.conf:/etc/apache2/sites-available/sugar.conf:ro
            - ../../images/php/82/apache/config/php/docker.ini:/usr/local/etc/php/conf.d/docker.ini:ro
            - ../../images/php/82/apache/config/php/docker-php-ext-redis.ini:/usr/local/etc/php/conf.d/docker-php-ext-redis.ini:ro
            - ../../images/php/82/apache/config/php/tideways.ini:/usr/local/etc/php/conf.d/tideways.ini:ro
            - ../../images/php/82/apache/config/php/xhprof.ini:/usr/local/etc/php/conf.d/xhprof.ini:ro
        depends_on:
            elasticsearch:
                condition: service_healthy
            mysql:
                condition: service_healthy
            permissions:
                condition: service_completed_successfully
        links:
            - mysql
            - elasticsearch

    suitecron:
        container_name: ${BASE_NAME}-cron
        image: sugarcrmdevelopers/sugardockerized:php8.2-cron-latest
        volumes:
            - type: bind
              source: ../../data/app
              target: /var/www/html
            - ../../images/php/82/cron/config/php/docker.ini:/usr/local/etc/php/conf.d/docker.ini:ro
        depends_on:
            elasticsearch:
                condition: service_healthy
            mysql:
                condition: service_healthy
            permissions:
                condition: service_completed_successfully
        links:
            - mysql
            - elasticsearch
